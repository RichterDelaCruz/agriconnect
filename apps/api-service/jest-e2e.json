{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@agriconnect/common(.*)$": "<rootDir>/../../packages/common/src$1",
    "^@agriconnect/database(.*)$": "<rootDir>/../../packages/database/src$1"
  }
}
